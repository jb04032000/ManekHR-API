  # First-time setup (fresh DB) — run the ledgered migrations (ADR-0001):
  #   npm run migrate            # apply all pending seeds/backfills (idempotent)
  # On an EXISTING prod DB whose data already reflects the old boot backfills:
  #   npm run migrate -- --baseline   # mark one-shot migrations applied, then `npm run migrate`
  # Optional dev convenience — run migrations once at boot (worker/all roles only):
  #   RUN_MIGRATIONS_ON_BOOT=true
  # (The old SEED_DEFAULTS_ON_BOOTSTRAP flag is removed — RUN_MIGRATIONS_ON_BOOT replaces it.)

# App
PORT=3000
NODE_ENV=development

# Admin bootstrap (one-time setup — set a strong random secret)
ADMIN_SETUP_SECRET=

# Database
MONGODB_URI=mongodb://localhost:27017/manekhr

# JWT
JWT_ACCESS_SECRET=your-access-secret-key-here
JWT_ACCESS_EXPIRY=30d
JWT_REFRESH_SECRET=your-refresh-secret-key-here
JWT_REFRESH_EXPIRY=180d

# Auth refresh-token cookie (OQ-1, auth-hardening). The web client's refresh
# token lives in an httpOnly cookie instead of localStorage (XSS hardening).
# AUTH_COOKIE_SECURE  - Secure flag. Defaults to true in production, false
#                       otherwise (so http://localhost dev works). Set true in
#                       any TLS environment.
# AUTH_COOKIE_SAMESITE- lax (default) | strict | none. Use 'none' (requires
#                       Secure) ONLY when web + API are on different sites; for a
#                       proxied / same-site deploy keep 'lax'. NOTE: setting
#                       'none' auto-forces AUTH_COOKIE_SECURE=true (and logs a
#                       warning) because browsers drop SameSite=None without
#                       Secure.
# AUTH_COOKIE_DOMAIN  - optional shared cookie domain (e.g. .manekhr.in) so the
#                       cookie spans api/app subdomains. Unset = host-only.
AUTH_COOKIE_SECURE=
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# App
WEB_APP_URL=http://localhost:3001
INVITE_TOKEN_EXPIRY_DAYS=14

# Firebase Admin SDK (Placeholder for Push Notifications / Auth Verification)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="your-firebase-private-key-replace-newlines"

# External Services (e.g. Storage, SMS, Redis)
# REDIS_URL=redis://localhost:6379
# TWILIO_ACCOUNT_SID=your-twilio-sid

# Mail configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
# MAIL_SECURE=false

# Atlas Search (set true on Atlas deployments to replace $regex team search)
# Requires index 'team_members_search' on the teammembers collection (see docs)
ATLAS_SEARCH_ENABLED=false

# Storage Configuration
# Use 'local' for development, 'r2' for production (Cloudflare R2)
STORAGE_PROVIDER=local
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/png,image/webp,application/pdf
UPLOADS_DIR=./uploads
# Private (signed-URL) media for chat attachments + job-application files.
# Local dev only: a separate, NON-statically-served dir + an HMAC secret for the
# token-checked dev route. Production uses R2 presigned URLs and ignores these.
UPLOADS_PRIVATE_DIR=./uploads-private
UPLOADS_PRIVATE_DEV_SECRET=change-me-in-dev

# Cloudflare R2 Storage (set STORAGE_PROVIDER=r2 to activate)
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_BUCKET_NAME=your-r2-bucket-name
# Second, NON-public bucket for PRIVATE media (chat + job-application files).
# Reuses the same account + credentials as R2_BUCKET_NAME; only the name differs.
# REQUIRED once any private upload happens in prod — if unset, a private upload
# fails loudly (it is never silently stored on the public bucket). Create this
# bucket with NO public access / no public-bucket URL.
R2_PRIVATE_BUCKET_NAME=your-r2-private-bucket-name
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Public URL: your custom domain or the R2 public bucket URL
# e.g. https://assets.yourdomain.com  or  https://pub-xxxx.r2.dev
R2_PUBLIC_URL=https://your-r2-public-url.com

# ════════════════════════════════════════════════════════════════════
# Brand asset URLs (consumed by emails + PDFs)
# ════════════════════════════════════════════════════════════════════
# Defaults compose ${R2_PUBLIC_URL}/brand/<filename> automatically — leave
# blank to use defaults. Override only when a CDN subpath / custom host
# differs from the bucket public URL.
#
# Files expected at ${R2_PUBLIC_URL}/brand/:
#   email-header.png             Card 12 — 600x200    top of every email
#   email-signature.png          Card 13 — 520x160    email signature (FLAGGED .com → .in)
#   invoice-header.png           Card 14 — 2480x600   PDF invoice header (FLAGGED)
#   watermark.png                Card 15 — 800x800    payslip PDF watermark
#   letterhead-a4.png            Card 16 — 2480x3508  A4 letterhead (FLAGGED)
#   tagline-lockup-inline.png    Card 09 — 1200x600
#   tagline-lockup-stacked.png   Card 10 — 800x600
#   tagline-lockup-editorial.png Card 10b — 1200x600
BRAND_EMAIL_HEADER_URL=
BRAND_EMAIL_SIGNATURE_URL=
BRAND_INVOICE_HEADER_URL=
BRAND_WATERMARK_URL=
BRAND_LETTERHEAD_URL=
BRAND_TAGLINE_INLINE_URL=
BRAND_TAGLINE_STACKED_URL=
BRAND_TAGLINE_EDITORIAL_URL=

# Phase 16 — Customer Portal token signing (separate from JWT_SECRET)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PORTAL_TOKEN_SECRET=

# Phase 17 — SurePass GSTIN filing-status (FIN-16-02)
# When set to 1, SurepassProvider.fetchFilingStatus() returns [] without
# making external calls (manual-recheck-only mode). See
# .planning/phases/17-party-intelligence-crm/17-SUREPASS-SPIKE.md.
SUREPASS_FILING_STUB=1
# Optional — only set if filing-status SKU requires a separate API key from
# SUREPASS_API_KEY. Spike doc §4 details the verification flow.
# SUREPASS_FILING_API_KEY=

# ════════════════════════════════════════════════════════════════════
# Phase D1 — SaaS subscription billing (Razorpay platform credentials)
# ════════════════════════════════════════════════════════════════════
# Distinct from per-firm Razorpay keys used by party-portal payment links.
# Required from D1b onward. Behaviour when missing:
#   - dev  : RazorpayPlatformService logs warn, /checkout returns 503.
#   - prod : RazorpayPlatformService throws at boot — app does NOT start.
#
# ── SETUP CHECKLIST (TODO before going live) ────────────────────────
# [ ] STEP 1 — Razorpay Dashboard → Settings → API Keys → Generate
#              test-mode key pair. Paste both values below.
#              URL: https://dashboard.razorpay.com/app/keys
RAZORPAY_PLATFORM_KEY_ID=
RAZORPAY_PLATFORM_KEY_SECRET=
#
# [ ] STEP 2 — Razorpay Dashboard → Settings → Webhooks → + Add Webhook
#              Webhook URL: https://<your-public-domain>/razorpay/webhook
#              (NOT under /api — see main.ts global-prefix exclude list)
#              Local dev: tunnel via ngrok / cloudflared first.
#              Generate a strong secret (32+ random bytes), paste below
#              AND into the Razorpay dashboard "Secret" field — must
#              match exactly. HMAC-SHA256 verify is the only auth on
#              that endpoint.
#              Generate cmd:
#                node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RAZORPAY_PLATFORM_WEBHOOK_SECRET=
#
# [ ] STEP 3 — In the Razorpay webhook config, subscribe to these events:
#                payment.captured           (D1b/D1d — closes abandoned-tab gap)
#                payment.failed             (D1d — marks SubscriptionPayment.failed)
#                refund.created             (D1d — pushes refund subdoc)
#                refund.processed           (D1d — finalises refund status)
#                subscription.activated     (D1c — flips pending->active, supersedes prior sub)
#                subscription.charged       (D1c — recurring renewal: extends period + writes payment row)
#                subscription.halted        (D1d — flips status=past_due, increments failedPaymentAttempts)
#                subscription.cancelled     (D1d — marks cancelled)
#                subscription.paused        (D1c — confirms pause took effect on gateway)
#                subscription.resumed       (D1c — confirms resume took effect on gateway)
#                subscription.completed     (D1c — total_count cycles consumed, marks expired)
#                subscription.expired       (D1c — end_at reached, marks expired)
#                payment_link.paid          (D1i — admin-issued payment link succeeded → create Subscription)
#                payment_link.cancelled     (D1i — admin recalled link → mark seed payment failed)
#                payment_link.expired       (D1i — link timed out → mark seed payment failed)
#
# [ ] STEP 4 — Switch to live-mode keys before production cutover.
#              Re-run STEPS 1-3 against the live-mode dashboard.
#              Keep test + live secrets in separate environments.

# ════════════════════════════════════════════════════════════════════
# Phase D1 — Platform legal entity (GST B2B invoice header, D1f)
# ════════════════════════════════════════════════════════════════════
# Single tenant: ManekHR's own legal info on every invoice PDF.
# Required before D1f (invoice generation) ships. Until then unused.
#
# ── SETUP CHECKLIST (TODO before D1f / first paid invoice) ──────────
# [ ] Fill GSTIN + PAN from registered legal entity docs.
# [ ] STATE_CODE = first 2 digits of GSTIN (place-of-supply rule).
#     E.g. 27 = Maharashtra, 24 = Gujarat, 29 = Karnataka.
# [ ] Pick a stable INVOICE_PREFIX — appears in invoice number forever.
#     Format: <PREFIX>-FY<YY>-<SEQ>.
PLATFORM_LEGAL_NAME=ManekHR
PLATFORM_LEGAL_GSTIN=
PLATFORM_LEGAL_PAN=
PLATFORM_LEGAL_ADDRESS_LINE1=
PLATFORM_LEGAL_ADDRESS_LINE2=
PLATFORM_LEGAL_CITY=
PLATFORM_LEGAL_STATE=
PLATFORM_LEGAL_STATE_CODE=
PLATFORM_LEGAL_PINCODE=
PLATFORM_LEGAL_EMAIL=
PLATFORM_LEGAL_PHONE=
PLATFORM_INVOICE_PREFIX=MNK

# ════════════════════════════════════════════════════════════════════
# Wave 8 — MSG91 SMS provider (DLT-compliant transactional SMS)
# ════════════════════════════════════════════════════════════════════
# MSG91 docs: https://docs.msg91.com/overview
# Wholesale per-segment cost (paise) drives margin reports + monthly
# invoice reconciliation. Customer-facing credit-pack pricing sits in
# `seed-default-add-ons.ts`. Adjust these env vars whenever MSG91
# publishes a rate change — a NEW row is appended to `msg91costtable`
# the next time the seeder runs (history preserved for reconciliation).
#
# ── SETUP CHECKLIST (TODO before SMS reminders go live) ─────────────
# [ ] STEP 1 — MSG91 Dashboard → API → Auth Key. Paste below.
#              URL: https://control.msg91.com/app/api
MSG91_AUTH_KEY=
#
# [ ] STEP 2 — MSG91 Dashboard → SMS → DLT → register your sender ID
#              with TRAI. 6-character header-id (e.g. "CRWRST"). Paste
#              the approved sender ID below. Required for every send —
#              MSG91 rejects un-registered headers.
MSG91_SENDER_ID=
#
# [ ] STEP 3 — Register a DLT-approved payment-reminder template body
#              on MSG91 + the partnered DLT registrar. Default substitution
#              maps VAR1..VAR4 → partyName / invoiceNumber / amount /
#              daysPastDue (see `SmsService.sendPaymentReminderSms`).
#              Paste the MSG91 flow_id below.
MSG91_PAYMENT_REMINDER_TEMPLATE_ID=
#
# [ ] STEP 3b — Register a DLT-approved auth-OTP template (single VAR1 = OTP
#              code). Suggested template body:
#                "{#var#} is your manekhr verification code. Do not share."
#              Paste the MSG91 flow_id below. Required when AUTH_OTP_MOCK is
#              off (production). Without this set the auth-OTP send path
#              returns SERVICE_DEGRADED and FE falls back to password login.
MSG91_AUTH_OTP_TEMPLATE_ID=
#
# [ ] STEP 4 — Wholesale per-segment cost in paise. Default 1500 = ₹0.15
#              per GSM-7 segment. Adjust based on your MSG91 commercial
#              contract. Cost-table seeder writes a NEW row when this
#              env var changes — historical rows close out via
#              `effectiveTo` so monthly reconciliation stays accurate.
MSG91_COST_GSM7_SEG_PAISE=1500
MSG91_COST_UCS2_SEG_PAISE=1500
#
# Behaviour when MSG91_AUTH_KEY missing:
#   - `Msg91BalanceService` cron logs `debug` and skips the poll
#     (no spurious `-1` snapshots).
#   - `SmsService.sendDltSms` logs `[SMS SKIP]` per call + writes a
#     SmsDispatchLog with status=skipped — never crashes the parent op.

# ════════════════════════════════════════════════════════════════════
# Wave 8 — AiSensy WhatsApp BSP (utility-template only)
# ════════════════════════════════════════════════════════════════════
# AiSensy docs: https://www.aisensy.com/api
# Pricing: 1 credit = 1 conversation per peer per 24h window (matches
# Meta 2023+ pricing). `WhatsappConversationWindow` collection tracks
# open windows; subsequent sends to the same peer within 24h consume
# 0 credits.
#
# ── SETUP CHECKLIST ────────────────────────────────────────────────
# [ ] STEP 1 — AiSensy Dashboard → API Keys → generate. Paste below.
AISENSY_API_KEY=
#
# [ ] STEP 2 — Default campaign name (utility template) for payment
#              reminders. Override per-rule via WhatsApp template
#              picker in the reminder rule editor.
AISENSY_PAYMENT_REMINDER_CAMPAIGN=payment_reminder_overdue

# ════════════════════════════════════════════════════════════════════
# Wave 8 — Free-tier trial credits (one-shot per workspace)
# ════════════════════════════════════════════════════════════════════
# Granted on first workspace create. Atomic flip via
# `appliedEntitlements.communications.lifetimeTrialGranted` — re-creating
# a workspace does NOT re-grant. Override defaults if desired.
TRIAL_SMS_CREDITS=10
TRIAL_WHATSAPP_CREDITS=5

# ════════════════════════════════════════════════════════════════════
# Wave 8.1 — Ops alerting (MSG91 wallet runway exhaustion)
# ════════════════════════════════════════════════════════════════════
# Triggered when:
#   - Customer purchases a credit pack but our MSG91 wallet doesn't have
#     runway to cover the implied volume.
#   - Reminder dispatcher detects empty MSG91 wallet at run start.
#
# Three channels (email primary; in-app + SMS secondary). Throttled at
# OPS_ALERT_THROTTLE_DAYS cadence (default 7d) so a sustained outage
# doesn't pager-bomb ops.
#
# ── SETUP CHECKLIST ────────────────────────────────────────────────
# [ ] STEP 1 — Ops mailbox that receives the email alert. Required for
#              Wave 8.1 ops resilience to be useful. Use a shared inbox
#              that on-call ops monitors.
OPS_MSG91_ALERT_EMAIL=
#
# [ ] STEP 2 (optional) — Ops phone to receive the DLT-templated alert
#              SMS. Tertiary channel — fails gracefully if MSG91 wallet
#              itself is empty (the very condition we're alerting on),
#              so email + in-app must still cover the gap.
OPS_MSG91_ALERT_SMS_MOBILE=
#
# [ ] STEP 3 (optional) — DLT template id for the ops alert SMS. Suggested
#              template body:
#                "MSG91 wallet at Rs.{#VAR1#}. Runway {#VAR2#} days. Top up
#                 at https://msg91.com/dashboard"
#              Register on MSG91 + DLT registrar, paste flow_id below.
OPS_MSG91_ALERT_DLT_TEMPLATE_ID=
#
# [ ] STEP 4 (optional) — Workspace id used to scope the ops-SMS dispatch.
#              Reuse a dedicated platform-ops workspace, NOT a customer's.
#              When unset, ops-SMS is silently skipped (email + in-app
#              still fire).
OPS_ALERT_WORKSPACE_ID=
#
# Throttle window in days for `msg91_topup_needed` alert key. Increase
# to 14 if you take longer to top up; decrease to 1 for high-traffic
# deployments where stale alerts are unhelpful.
OPS_ALERT_THROTTLE_DAYS=7
#
# Pre-flight safety multiplier — required runway = est cost × this.
# Default 1.5× compensates for up-to-60min staleness between hourly
# wallet polls. Crank to 2.0 if your wallet drains fast or polling
# sometimes fails.
MSG91_PREFLIGHT_SAFETY_MULTIPLIER=1.5
#
# AiSensy WhatsApp passthrough cost (paise per conversation). Used only
# in pre-flight cost estimation for purchase-time ops alerts. Per-send
# rate-card not modeled today.
AISENSY_COST_PER_CONVERSATION_PAISE=4000


FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-firebase-client-email
FIREBASE_PRIVATE_KEY="your-firebase-private-key-replace-newlines"


# ════════════════════════════════════════════════════════════════════
# Phase 0.9 — Sentry (crash reporting + perf monitoring)
# ════════════════════════════════════════════════════════════════════
# Create a Node.js project at https://sentry.io and copy the DSN here.
# Empty value → SDK ships in no-op mode (does not crash boot).
SENTRY_DSN=
# Override environment tag (default: NODE_ENV)
SENTRY_ENV=
# Build-time source-map upload (server-only, secret).
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ════════════════════════════════════════════════════════════════════
# Phase 4 — PostHog server SDK (subscription/billing/critical events)
# ════════════════════════════════════════════════════════════════════
# Same project as web SDK; keys are independent.
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# ════════════════════════════════════════════════════════════════════
# Phase 4 — OpenTelemetry exporter (APM / distributed tracing)
# ════════════════════════════════════════════════════════════════════
# Pick one vendor: Datadog / Honeycomb / New Relic / Grafana Cloud.
# Empty → tracer initialized in no-op mode (no traces emitted).
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=manekhr-backend
# 1.0 = always sample. Lower (e.g. 0.1) once production traffic ramps.
OTEL_SAMPLE_RATE=1.0

# ════════════════════════════════════════════════════════════════════
# Phase 4 — Database backup destination (R2/S3 dedicated bucket)
# ════════════════════════════════════════════════════════════════════
# Used by the nightly mongodump cron. Keep the backup bucket separate
# from the asset bucket so retention + access policies can differ.
BACKUP_BUCKET=
BACKUP_ENDPOINT=
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=
BACKUP_RETENTION_DAYS=30

# ════════════════════════════════════════════════════════════════════
# Salary retention purge (Workstream G hardening, OQ-S4)
# ════════════════════════════════════════════════════════════════════
# System-only hard-erase of salary/payroll/statutory rows whose retention
# window has lapsed. DEFAULT OFF — leave false until the owner + CA approve.
# The 8y payroll/tax/statutory and 10y Gujarat-wage-register/daily-wage windows
# are a HARD CODE FLOOR (STATUTORY_PAYROLL_FLOOR_YEARS / STATUTORY_WAGE_FLOOR_YEARS
# in salary-retention-purge.cron.ts). These env values can ONLY EXTEND retention
# (keep records longer) — setting them BELOW the floor has no effect; the code
# clamps up to 8y/10y so statutory data can never be purged early. A workspace may
# also extend (never shorten) via PayrollConfig. See
# docs/compliance/DATA-MAP-AND-RETENTION.md §2.
RUN_RETENTION_PURGE_ON_SCHEDULE=false
SALARY_RETENTION_PAYROLL_YEARS=8
SALARY_RETENTION_WAGE_LEDGER_YEARS=10
# Attendance + Finance/Bills retention purges share the SAME master switch above
# (RUN_RETENTION_PURGE_ON_SCHEDULE) and the same code-floor philosophy. Their
# windows have HARD code floors (STATUTORY_MUSTER_FLOOR_YEARS=10 in
# attendance-retention-purge.cron.ts; STATUTORY_FINANCE_FLOOR_YEARS=8 in
# bills-retention-purge.cron.ts) — these env values can only EXTEND, never shorten
# below the floor. The Finance/Bills purge erases ONLY soft-deleted legacy Bill
# rows past the window — never ledger entries or posted Finance vouchers.
ATTENDANCE_RETENTION_MUSTER_YEARS=10
ATTENDANCE_RETENTION_DISPATCH_YEARS=1
BILLS_RETENTION_FINANCE_YEARS=8
# RBAC override retention cleaner — also shares the master switch above. Clears the
# per-member access-control overrides (TeamMember.permissionOverrides +
# permissionPathOverrides) on members removed longer than the keep window. Owner
# decision (2026-06-15): revoke access at offboard (the leftover overrides are
# already inert for a removed member), then KEEP the override record ~1y for audit
# and auto-clear after. Code floor (RBAC_OVERRIDE_KEEP_FLOOR_YEARS=1 in
# rbac-override-retention.cron.ts) — an env value below it cannot shorten the
# window. NEVER touches active members or Role definitions; scrubs config arrays
# only, never hard-deletes a row.
RBAC_RETENTION_OVERRIDE_KEEP_YEARS=1
# Workspace retention purge — also shares the master switch above. Scrubs Bucket-C
# profile/config fields (branding logos, notification policy, self-service config,
# party intelligence, autoAcceptKnownInvites, storage usage, app-lock idle, export
# prefs, residual SMTP host/port/user) from SOFT-DELETED workspaces past a grace
# window (anchored on deletedAt). NEVER deletes the workspace row or any statutory
# (Bucket-B) data; credentials (kiosk + ingest token + SMTP password) are already
# scrubbed immediately at delete time. Code floor (WORKSPACE_RETENTION_GRACE_FLOOR_DAYS=30
# in workspace-retention-purge.cron.ts) — an env value below it cannot shorten the
# grace window.
WORKSPACE_RETENTION_GRACE_DAYS=90

# ════════════════════════════════════════════════════════════════════
# Phase 4 — Production CORS allowlist
# ════════════════════════════════════════════════════════════════════
# Comma-separated list of allowed origins. Empty → dev mode (origin:true).
# Example: https://app.manekhr.in,https://portal.manekhr.in
CORS_ALLOWED_ORIGINS=

# ════════════════════════════════════════════════════════════════════
# Auth SMS-OTP (login / register / forgot / mobile verify)
# ════════════════════════════════════════════════════════════════════
# India-only +91. Provider: MSG91 (reuses SmsService.sendDltSms with
# creditSource='system' so platform pays for auth OTPs, not workspaces).
# Template: see MSG91_AUTH_OTP_TEMPLATE_ID above. Mock mode bypasses MSG91
# and accepts the fixed code "123456" — must be OFF in production.
#
# ── DEV / STAGING ──
#   AUTH_OTP_MOCK=true             # accept "123456" without burning credits
#   NEXT_PUBLIC_AUTH_OTP_MOCK=true # FE banner "Mock OTP active — use 123456"
#
# ── PRODUCTION ──
#   AUTH_OTP_MOCK=                 # unset (or false)
#   NEXT_PUBLIC_AUTH_OTP_MOCK=     # unset (or false)
#   MSG91_AUTH_OTP_TEMPLATE_ID=<DLT-approved template id>
#   AUTH_OTP_WORKSPACE_ID=<seeded platform-auth-otp workspace _id>
#
# Triple-lock: setting AUTH_OTP_MOCK=true with NODE_ENV=production raises
# FATAL at boot unless ALLOW_AUTH_OTP_MOCK_IN_PROD=true is ALSO set
# (war-room toggle only).
AUTH_OTP_MOCK=true
ALLOW_AUTH_OTP_MOCK_IN_PROD=
#
# Synthetic platform workspace _id used as `workspaceId` on SmsDispatchLog
# rows for auth OTPs. Seeded by SeedPlatformAuthOtpWorkspaceService via the
# migration runner (`npm run migrate`, unit 0031); copy the logged _id back here.
AUTH_OTP_WORKSPACE_ID=
#
# ── OTP CHANNEL (2026-07) ──────────────────────────────────────────────
# Which MSG91 product actually sends/verifies the SMS. Added because DLT
# sender-ID registration (the settings above) can take weeks; the Widget
# product ships OTP today on a pre-approved route, no DLT needed.
#   widget (default) - MSG91's OTP Widget. Browser SDK sends+verifies the
#                       code; this backend only confirms the resulting
#                       access-token via Msg91WidgetOtpService. Needs
#                       MSG91_WIDGET_ID below (client tokenAuth lives in
#                       web's NEXT_PUBLIC_MSG91_WIDGET_TOKEN_AUTH).
#   dlt               - the original raw-SMS path via sendDltSms, using
#                       MSG91_AUTH_OTP_TEMPLATE_ID + AUTH_OTP_WORKSPACE_ID
#                       above. Switch back to this once your DLT sender ID
#                       clears if you'd rather not depend on the Widget.
# Both channels reuse MSG91_AUTH_KEY (top of this file) for server calls.
# See docs/superpowers/specs/2026-07-03-msg91-widget-otp-design.md.
AUTH_OTP_CHANNEL=widget
#
# Widget ID from MSG91 dashboard → OTP Widget/SDK → Widgets. Required when
# AUTH_OTP_CHANNEL=widget; ignored for the dlt channel.
MSG91_WIDGET_ID=
#
# OTP token TTL (ms). Default 600 000 = 10 min. Mirrors email-verification.
AUTH_OTP_EXPIRY_MS=600000
#
# Min seconds between Resend clicks for the same phone. UI countdown mirrors.
AUTH_OTP_RESEND_COOLDOWN_SEC=30
#
# Wrong-OTP attempts before per-phone lockout kicks in.
AUTH_OTP_MAX_VERIFY_ATTEMPTS=5
#
# Lockout window (minutes) once max attempts hit.
AUTH_OTP_LOCKOUT_MINUTES=30
#
# Per-phone send caps (Redis sliding window).
AUTH_OTP_RATE_LIMIT_HOURLY=5
AUTH_OTP_RATE_LIMIT_DAILY=10
#
# Per-IP daily cap — defends against attacker rotating phone numbers.
AUTH_OTP_PER_IP_DAILY=20
#
# Provider circuit breaker — halts auth-OTP sends after N MSG91 failures
# inside windowSec. Returns SERVICE_DEGRADED until the window rolls.
AUTH_OTP_CIRCUIT_BREAKER_THRESHOLD=25
AUTH_OTP_CIRCUIT_BREAKER_WINDOW_SEC=300
# ════════════════════════════════════════════════════════════════════
# ManekHR Connect — Meilisearch (people / entity search)
# ════════════════════════════════════════════════════════════════════
# Backs the `connect/search` endpoint. Empty MEILI_HOST → SearchService
# transparently falls back to a Mongo-regex search, so a missing
# Meilisearch deployment never breaks search. Provision before Phase 7.
#   MEILI_HOST   — base URL of the Meilisearch instance (e.g. http://localhost:7700)
#   MEILI_API_KEY — a key with search + documents + indexes scope
MEILI_HOST=
MEILI_API_KEY=

# ManekHR Connect — search engine cache (SRCH-PERF-1)
# ────────────────────────────────────────────────────────────────────
# Short-TTL Redis prefix cache fronting the Meilisearch engine round-trip
# for `connect/search` (typeahead). It caches ONLY the viewer-independent
# engine output (hit ids + facet counts), NEVER the post-hydration result —
# the live author-active gate AND the per-viewer block filter still run on
# every request, so a cache hit can never leak blocked/banned content. It
# degrades to a direct live query when REDIS_URL is unset or Redis faults.
#   CONNECT_SEARCH_CACHE_TTL_SECONDS — cache window in seconds (spec 30–60).
#                                      Default 45. Set to 0 to disable the cache.
# CONNECT_SEARCH_CACHE_TTL_SECONDS=45


# ════════════════════════════════════════════════════════════════════
# Additional runtime variables (documented 2026-06-26 — deployment readiness)
# All are read by src/config/env.ts and have safe code defaults, so the app
# boots without them. Listed here so production config is complete. Secrets are
# left blank on purpose — set them in your secret store, never commit real ones.
# ════════════════════════════════════════════════════════════════════

# ---- Process role / URLs / paging ----
# Role this process plays in a multi-process deploy: web | worker | all.
# Default 'all' (one process runs HTTP + crons + queues). Split to scale out.
PROCESS_ROLE=all
# Public base URL of the web app (used in links/emails). Trailing slash trimmed.
PUBLIC_WEB_URL=https://app.example.com
# App URL exposed to the client. Default http://localhost:3001.
NEXT_PUBLIC_APP_URL=http://localhost:3001
# List-endpoint page-size threshold before pagination is forced. Default 200.
PAGINATION_THRESHOLD=200
# 24-char hex ObjectId used as the actor for system-generated writes.
# Default all-zeroes; override only if you seed a dedicated system user.
SYSTEM_USER_ID=000000000000000000000000

# ---- DPDP / account deletion ----
# Where the deletion / grievance flow points users. Default derives to
# <WEB_APP_URL>/grievance. Set to your grievance contact URL.
ACCOUNT_DELETION_CONTACT_URL=

# ---- Encryption keys (SET IN PRODUCTION — secrets, keep out of git) ----
# Encrypts stored SMTP credentials. Empty = that encryption is off.
SMTP_ENCRYPTION_KEY=
# Encrypts sensitive employee fields (PAN/Aadhaar/bank/statutory IDs) at rest.
# REQUIRED in production for those fields to be protected.
FIELD_ENCRYPTION_KEY=

# ---- KYC / OCR providers ----
# Surepass API key (PAN/GST/bank verification). Secret — set in production.
SUREPASS_API_KEY=
# Google Document AI processor id for invoice/document OCR.
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=

# ---- App Lock (Quick-PIN) — keep in sync with web NEXT_PUBLIC_APP_LOCK_* ----
# Idle time (ms) before the Quick-PIN lock fires. Default 300000 (5 min).
APP_LOCK_IDLE_MS=300000
# Grace window (ms) after PIN setup before idle locking applies. Default 300000.
APP_LOCK_SETUP_GRACE_MS=300000
# Quick-PIN reset token lifetime. Default 5m.
APP_LOCK_RESET_TOKEN_EXPIRY=5m
# Failed PIN attempts before lockout. Default 5.
APP_LOCK_MAX_FAILED_ATTEMPTS=5

# ---- Observability ----
# Sentry release tag (maps an error spike to a build). Default: npm package
# version, else empty. Usually set by CI to the git SHA.
SENTRY_RELEASE=
# Sentry trace sample rate. Default 0.1 in production, 1.0 elsewhere.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Request log format: json (aggregators) | pretty (local).
# Default json in production, pretty otherwise.
LOG_FORMAT=json
# Comma list of Nest log levels to emit (e.g. log,warn,error,fatal).
# Default: warn,error,fatal in production; all levels in dev.
LOG_LEVELS=

# ---- Migrations / health / queue monitor ----
# Run the migration runner once at boot (worker/all roles only). Default false —
# production runs migrations via `npm run migrate` / a CI step.
RUN_MIGRATIONS_ON_BOOT=false
# Per-dependency health probe timeout (ms). Default 3000.
HEALTH_PROBE_TIMEOUT_MS=3000
# Queue-depth monitor cron on/off. Default true.
QUEUE_MONITOR_ENABLED=true
# Alert when a queue's waiting jobs exceed this. Default 500.
QUEUE_MONITOR_WAITING_THRESHOLD=500
# Alert when a queue's failed jobs exceed this. Default 50.
QUEUE_MONITOR_FAILED_THRESHOLD=50

# ---- ManekHR Connect feed / marketplace tunables ----
# Feed ranking strategy. Default 'default-additive'.
CONNECT_FEED_RANKING_STRATEGY=default-additive
# Down-rank factor (0–1) applied to demo/sample content in the feed. Default 0.35.
CONNECT_FEED_DEMO_PENALTY=0.35
# Require marketplace listings to pass moderation before going live. Default false.
CONNECT_LISTING_MODERATION_ENABLED=false
# Enforce Connect per-plan usage limits. Default true.
CONNECT_LIMITS_ENFORCED=true

# ---- Local dev tooling paths (i18n sync scripts; not needed in production) ----
MOBILE_APP_DIR=
WEB_APP_DIR=
MOBILE_TRANSLATIONS_DIR=
WEB_TRANSLATIONS_DIR=
