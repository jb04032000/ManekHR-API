# CrewRoster BACKEND (EC2) environment template — hybrid deploy.
# Copy to deploy/.env on the EC2 host and fill in. NEVER commit the real .env.
# The FRONTEND runs on AWS Amplify and reads its OWN env vars from the Amplify
# console (all the NEXT_PUBLIC_* client values) — they do NOT belong here.

# ---------- Host / domain (Caddy TLS for api.<DOMAIN>) ----------
DOMAIN=zari360.in                       # api.<DOMAIN> is served by this box
ACME_EMAIL=zari360app@gmail.com         # Let's Encrypt account email
NODE_ENV=production

# ---------- Database (MongoDB Atlas, Mumbai / ap-south-1) ----------
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/zari360?retryWrites=true&w=majority

# ---------- Redis (in-stack container) ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME                 # openssl rand -hex 32

# ---------- URLs / CORS ----------
WEB_APP_URL=https://zari360.in           # the Amplify-served frontend origin
PUBLIC_WEB_URL=https://zari360.in
NEXT_PUBLIC_APP_URL=https://zari360.in
# Lock CORS to the frontend origin(s). Must include the Amplify domain.
CORS_ALLOWED_ORIGINS=https://zari360.in,https://www.zari360.in
# Auth cookie shared across the root + api subdomain.
AUTH_COOKIE_DOMAIN=.zari360.in
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true

# ---------- Auth / JWT (openssl rand -hex 32 each) ----------
JWT_ACCESS_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
ADMIN_SETUP_SECRET=CHANGE_ME
# REQUIRED — the app fails to boot without this (signs customer-portal access
# tokens). Generate with: openssl rand -hex 32
PORTAL_TOKEN_SECRET=CHANGE_ME

# ---------- Migrations: served containers never self-migrate (the gate does) ----------
RUN_MIGRATIONS_ON_BOOT=false

# ---------- Monitoring (Sentry, server-side) ----------
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_RELEASE=

# ---------- Backups ----------
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30
BACKUP_BUCKET=
BACKUP_ENDPOINT=
BACKUP_ACCESS_KEY=
BACKUP_SECRET_KEY=

# ---------- File storage (Cloudflare R2) ----------
STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_PRIVATE_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

# ---------- Integrations (fill the ones you use) ----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_ENCRYPTION_KEY=
RAZORPAY_PLATFORM_KEY_ID=
RAZORPAY_PLATFORM_KEY_SECRET=
RAZORPAY_PLATFORM_WEBHOOK_SECRET=
MSG91_AUTH_KEY=
AISENSY_API_KEY=
