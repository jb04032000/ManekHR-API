{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "build": "nest build && npm run copy:assets",
    "copy:assets": "node -e \"const fs=require('fs'),p=require('path');function cp(s,d,filter){fs.mkdirSync(d,{recursive:true});for(const f of fs.readdirSync(s)){const sp=p.join(s,f),dp=p.join(d,f);if(fs.statSync(sp).isDirectory()){cp(sp,dp,filter)}else if(!filter||filter(f)){fs.copyFileSync(sp,dp)}}}cp('src/i18n','dist/i18n');cp('src/modules/mail/templates','dist/modules/mail/templates');console.log('assets copied (i18n + mail templates; print fonts come from the swc build)')\"",
    "format": "prettier --write \"{src,test,scripts}/**/*.{ts,js,json,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"{src,test,scripts}/**/*.{ts,js,json,md}\" --ignore-path .prettierignore",
    "typecheck": "node --max-old-space-size=16384 --stack-size=16000 ./node_modules/typescript/bin/tsc --noEmit",
    "redis:start": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-redis.ps1",
    "prestart": "npm run redis:start",
    "start": "nest start",
    "prestart:dev": "npm run redis:start",
    "start:dev": "npm run copy:assets && nest start --watch",
    "prestart:debug": "npm run redis:start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:prod:web": "PROCESS_ROLE=web node dist/main",
    "start:prod:worker": "PROCESS_ROLE=worker node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:vitest": "vitest run",
    "test:vitest:watch": "vitest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/jest/bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "ts-node --transpile-only -r tsconfig-paths/register src/seed.ts",
    "migrate": "ts-node --transpile-only -r tsconfig-paths/register src/migrate.ts",
    "backup": "ts-node --transpile-only -r tsconfig-paths/register scripts/backup-db.ts",
    "backup:restore": "ts-node --transpile-only -r tsconfig-paths/register scripts/restore-db.ts",
    "backup:verify": "ts-node --transpile-only -r tsconfig-paths/register scripts/verify-backup-restore.ts",
    "seed:translations": "ts-node -r tsconfig-paths/register src/seed-translations.ts",
    "validate:i18n": "ts-node -r tsconfig-paths/register scripts/validate-i18n.ts",
    "validate:i18n:mobile": "ts-node -r tsconfig-paths/register scripts/validate-i18n.ts --platform=mobile",
    "validate:i18n:web": "ts-node -r tsconfig-paths/register scripts/validate-i18n.ts --platform=web",
    "migrate:attendance-date": "ts-node -r tsconfig-paths/register scripts/backfill-attendance-date.ts",
    "export:upload-policies": "ts-node -r tsconfig-paths/register scripts/export-upload-policies.ts",
    "seed:connect": "ts-node -r tsconfig-paths/register scripts/seed-connect.ts",
    "set:demo-passwords": "ts-node -r tsconfig-paths/register scripts/set-demo-passwords.ts",
    "connect:autopost": "ts-node -r tsconfig-paths/register scripts/connect-auto-post.ts",
    "connect:demo:clear": "ts-node -r tsconfig-paths/register scripts/connect-demo-clear.ts",
    "connect:demo:list": "ts-node -r tsconfig-paths/register scripts/connect-demo-list.ts",
    "connect:demo:restamp": "ts-node -r tsconfig-paths/register scripts/connect-demo-restamp-isdemo.ts",
    "connect:demo:verify": "ts-node -r tsconfig-paths/register scripts/connect-demo/verify-demo-content.ts",
    "backfill:connect-enabled": "ts-node -r tsconfig-paths/register scripts/backfill-connect-enabled.ts",
    "backfill:connect-follows": "ts-node -r tsconfig-paths/register scripts/backfill-connection-follows.ts"
  },
  "engines": {
    "npm": ">=10.0.0",
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@aws-sdk/s3-request-presigner": "^3.1066.0",
    "@nestjs-modules/mailer": "^2.3.4",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.0.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.11",
    "@nestjs/platform-socket.io": "^11.1.21",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.21",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@sentry/nestjs": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/ua-parser-js": "^0.7.39",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.2",
    "bwip-js": "^4.10.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.20",
    "file-type": "^16.5.4",
    "firebase-admin": "^13.8.0",
    "fontkit": "^2.0.4",
    "geoip-lite": "^1.4.10",
    "google-auth-library": "^10.6.1",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "image-size": "^1.2.1",
    "ioredis": "^5.10.1",
    "js-yaml": "^4.1.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lru-cache": "^5.1.1",
    "mongoose": "^8.23.0",
    "multer": "^2.1.1",
    "music-metadata": "^7.14.0",
    "nodemailer": "^8.0.1",
    "p-limit": "^3.1.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.18.0",
    "posthog-node": "^4.5.0",
    "qrcode": "^1.5.4",
    "razorpay": "^2.9.6",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "ua-parser-js": "^2.0.9",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.15.32",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/fontkit": "^2.0.9",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.11",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "autocannon": "^8.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "fast-xml-parser": "^5.7.2",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.4.0",
    "mongodb-memory-server": "^9.5.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@swc/core"
    ]
  }
}
