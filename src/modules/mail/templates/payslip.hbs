<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; color: #333; margin: 0; padding: 0; }
    .container { max-width: 600px; margin: 0 auto; padding: 32px 24px; }
    .header { background: #1a1a2e; color: white; padding: 24px; border-radius: 8px 8px 0 0; }
    .header h1 { margin: 0; font-size: 20px; }
    .header p { margin: 4px 0 0; font-size: 13px; opacity: 0.8; }
    .body { background: #f9f9f9; padding: 24px; border: 1px solid #e5e5e5; }
    .highlight { background: white; border-radius: 8px; padding: 16px 20px;
                 margin: 16px 0; border-left: 4px solid #4f46e5; }
    .highlight p { margin: 4px 0; font-size: 14px; }
    .highlight .label { color: #666; font-size: 12px; }
    .highlight .value { font-weight: bold; font-size: 16px; color: #1a1a2e; }
    .footer { background: #f0f0f0; padding: 16px 24px;
              border-radius: 0 0 8px 8px; text-align: center; }
    .footer p { margin: 0; font-size: 12px; color: #888; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <img src="{{brand.emailHeader}}" alt="ManekHR" style="max-width:240px;height:auto;display:block;margin:0 auto 16px;border:0;outline:none;text-decoration:none;" />
      <h1>{{workspaceName}}</h1>
      <p>Payslip for {{monthLabel}} {{year}}</p>
    </div>
    <div class="body">
      <p>Dear {{employeeName}},</p>
      <p>Please find your payslip for <strong>{{monthLabel}} {{year}}</strong>
         attached to this email.</p>

      <div class="highlight">
        <p class="label">Net Salary</p>
        <p class="value">{{currencySymbol}}{{netSalary}}</p>
      </div>

      <div class="highlight">
        <p class="label">Pay Period</p>
        <p class="value">{{monthLabel}} {{year}}</p>
        <p class="label" style="margin-top:8px">Status</p>
        <p class="value">{{paymentStatus}}</p>
      </div>

      <p style="font-size:13px;color:#666;">
        Your payslip is attached as a PDF. Please keep it for your records.
        For any queries, contact your HR or payroll administrator.
      </p>
    </div>
    <div class="footer">
      <p>This email was sent by {{workspaceName}} using ManekHR.</p>
      <p>For any queries, reply to this email or contact your HR administrator.</p>
    </div>
  </div>
</body>
</html>
