<!DOCTYPE html>
<html>
<body style="font-family: Arial, sans-serif; color: #333;">
  <img src="{{brand.emailHeader}}" alt="ManekHR" style="max-width:240px;height:auto;display:block;margin:0 auto 16px;border:0;outline:none;text-decoration:none;" />
  <h2>Regularization {{decisionType}}</h2>
  <p>Hi {{name}},</p>
  <p>The regularization request for <strong>{{memberName}}</strong> on <strong>{{date}}</strong> was {{decisionType}} by <strong>{{decisionByName}}</strong>.</p>
  <p><strong>Requested status:</strong> {{requestedStatus}}</p>
  {{#if note}}
  <p><strong>Note:</strong></p>
  <blockquote style="border-left: 3px solid #ccc; padding-left: 12px; color: #555;">{{note}}</blockquote>
  {{/if}}
  <p><a href="{{viewUrl}}">View details</a></p>
  <hr>
  <p style="color: #999; font-size: 12px;">Workspace: {{wsName}} — ManekHR</p>
</body>
</html>
