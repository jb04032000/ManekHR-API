<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <title>Workspace Invitation</title>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f4f4; margin: 0; padding: 0; }
        .container { background-color: #ffffff; max-width: 600px; margin: 20px auto; padding: 40px; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .header { text-align: center; margin-bottom: 30px; }
        .title { color: #333333; font-size: 24px; font-weight: bold; margin-bottom: 10px; }
        .text { color: #555555; font-size: 16px; line-height: 1.5; margin-bottom: 20px; }
        .workspace-card { background-color: #f8f9fa; border: 1px solid #e9ecef; border-radius: 8px; padding: 20px; margin: 20px 0; }
        .workspace-name { font-size: 20px; font-weight: bold; color: #333333; margin-bottom: 8px; }
        .workspace-meta { color: #666666; font-size: 14px; }
        .button-container { text-align: center; margin: 30px 0; }
        .button { background-color: #007bff; color: white !important; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-size: 16px; font-weight: bold; display: inline-block; }
        .secondary-link { display: block; margin-top: 15px; font-size: 14px; color: #007bff; text-decoration: none; }
        .footer { color: #999999; font-size: 14px; text-align: center; margin-top: 40px; border-top: 1px solid #eeeeee; padding-top: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <img src="{{brand.emailHeader}}" alt="ManekHR" style="max-width:240px;height:auto;display:block;margin:0 auto 16px;border:0;outline:none;text-decoration:none;" />
            <h1 class="title">ManekHR</h1>
        </div>
        
        <p class="text">Hi,</p>
        <p class="text">{{inviterName}} has invited you to join <strong>{{workspaceName}}</strong> as a {{role}}.</p>
        
        <div class="workspace-card">
            <div class="workspace-name">{{workspaceName}}</div>
            <div class="workspace-meta">
                {{#if workspaceType}}Type: {{workspaceType}}<br>{{/if}}
                Role: {{role}}
            </div>
        </div>
        
        <div class="button-container">
            <a href="{{inviteUrl}}" class="button">Accept Invitation</a>
            <a href="{{mobileDeepLink}}" class="secondary-link">Open in App</a>
        </div>
        
        <p class="text">This invitation will expire in {{expiryDays}} days.</p>
        <p class="text">If you were not expecting this invitation, you can safely ignore this email.</p>
        
        <div class="footer">
            &copy; 2026 ManekHR. All rights reserved.
        </div>
    </div>
</body>
</html>
