<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Attendance defaulter alert</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background:#f6f8fa; margin:0; padding:24px; color:#1f2937;">
  <img src="{{brand.emailHeader}}" alt="ManekHR" style="max-width:240px;height:auto;display:block;margin:0 auto 16px;border:0;outline:none;text-decoration:none;" />
  <div style="max-width:560px; margin:0 auto; background:#ffffff; border-radius:8px; padding:24px; border:1px solid #e5e7eb;">
    <h2 style="margin:0 0 12px 0; font-size:18px; color:#111827;">
      Attendance defaulters — {{monthLabel}}
    </h2>
    <p style="margin:0 0 16px 0; font-size:14px; line-height:1.5; color:#374151;">
      {{defaulters.length}} member(s) finished {{monthLabel}} below the
      {{thresholdPct}}% attendance threshold.
    </p>
    <table style="width:100%; border-collapse:collapse; font-size:13px;">
      <thead>
        <tr style="text-align:left; border-bottom:2px solid #e5e7eb;">
          <th style="padding:6px 8px; font-weight:600; color:#6b7280;">Member</th>
          <th style="padding:6px 8px; font-weight:600; color:#6b7280;">Designation</th>
          <th style="padding:6px 8px; text-align:right; font-weight:600; color:#6b7280;">Attendance</th>
        </tr>
      </thead>
      <tbody>
        {{#each defaulters}}
        <tr style="border-bottom:1px solid #f3f4f6;">
          <td style="padding:6px 8px; color:#111827;">{{this.name}}</td>
          <td style="padding:6px 8px; color:#6b7280;">{{this.designation}}</td>
          <td style="padding:6px 8px; text-align:right; font-weight:600; color:#dc2626;">
            {{this.ratePct}}%
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    <p style="margin:20px 0 24px;">
      <a href="{{complianceUrl}}" style="display:inline-block; padding:10px 18px; background:#111827; color:#ffffff; text-decoration:none; border-radius:6px; font-size:14px; font-weight:500;">Open the Compliance report</a>
    </p>
    <hr style="border:0; border-top:1px solid #e5e7eb; margin:16px 0;">
    <p style="margin:0; font-size:12px; color:#9ca3af; line-height:1.5;">This digest was sent because you manage attendance for this workspace. To stop receiving defaulter alerts, ask an admin to adjust the alert settings in Attendance &rarr; Settings &rarr; Defaulter alerts.</p>
  </div>
</body>
</html>
