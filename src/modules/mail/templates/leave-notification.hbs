<!DOCTYPE html>
<html>
<body style="font-family: Arial, sans-serif; color: #333;">
  <img src="{{brand.emailHeader}}" alt="ManekHR" style="max-width:240px;height:auto;display:block;margin:0 auto 16px;border:0;outline:none;text-decoration:none;" />
  <h2>{{headline}}</h2>
  <p>Hi {{name}},</p>
  <p>{{intro}}</p>
  <table style="border-collapse:collapse;margin:8px 0 12px;">
    {{#each lines}}
    <tr>
      <td style="padding:2px 16px 2px 0;color:#888;">{{this.label}}</td>
      <td style="padding:2px 0;"><strong>{{this.value}}</strong></td>
    </tr>
    {{/each}}
  </table>
  {{#if reason}}
  <p style="color:#888;margin-bottom:4px;">Reason</p>
  <blockquote style="border-left:3px solid #ccc;padding-left:12px;color:#555;margin:0 0 12px;">{{reason}}</blockquote>
  {{/if}}
  {{#if note}}
  <p style="color:#888;margin-bottom:4px;">Note</p>
  <blockquote style="border-left:3px solid #ccc;padding-left:12px;color:#555;margin:0 0 12px;">{{note}}</blockquote>
  {{/if}}
  <p><a href="{{ctaUrl}}" style="background:#1677ff;color:white;padding:10px 20px;text-decoration:none;border-radius:4px;display:inline-block;">{{ctaLabel}}</a></p>
  <hr>
  <p style="color:#999;font-size:12px;">Workspace: {{wsName}} — ManekHR</p>
</body>
</html>
